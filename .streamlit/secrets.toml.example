# Скопируйте этот файл в secrets.toml и заполните значения
# В Streamlit Cloud эти значения вводятся в настройках приложения (Settings → Secrets)

# Пароль для входа в калькулятор
APP_PASSWORD = "Remkon2026"

# URL экспорта Google Sheets (CSV) — опционально
# Как получить:
#   1. Открыть таблицу в Google Sheets
#   2. Файл → Поделиться → Доступ: Просмотр для всех
#   3. В адресной строке скопировать ID: docs.google.com/spreadsheets/d/{ID}/edit
#   4. Подставить ID сюда:
# SHEET_URL = "https://docs.google.com/spreadsheets/d/{ВАШ_ID}/export?format=csv&gid=0"
